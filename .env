# Admin (Vite) — public env only `VITE_*` is exposed to the browser.

# This admin app’s own origin (links, redirects if you add them later).
VITE_ADMIN_ORIGIN=http://localhost:5174

# Customer storefront (“View store”).
VITE_STORE_URL=http://localhost:8080

# Express API: Vite proxies `/api` here. No trailing slash.
VITE_BACKEND_ORIGIN=http://localhost:5000

# Optional: call the API directly. Leave unset for normal local dev.
# VITE_API_URL=http://localhost:5000

# Dev server port (must match how you open the admin UI).
VITE_ADMIN_PORT=5174
