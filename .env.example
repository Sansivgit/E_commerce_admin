# Public storefront URL (customer app)
VITE_STORE_URL=http://localhost:8080

# Optional: backend base URL (no trailing slash).
# Leave unset in development to use Vite’s `/api` proxy to Express on port 5000.
# Set for production preview or direct API access, e.g. VITE_API_URL=https://api.example.com
# VITE_API_URL=http://localhost:5000
